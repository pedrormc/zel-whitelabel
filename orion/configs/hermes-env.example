# Zel Instance — Hermes Gateway Config
# Copy to /home/<user>/.hermes/.env and fill in values

# Instance identity
ZEL_USER=adonai
ZEL_OWNER_NAME=Adonai
ZEL_BRIDGE_PORT=3001

# Gateway access (set true for shared number routing)
GATEWAY_ALLOW_ALL_USERS=true

# WhatsApp config
WHATSAPP_MODE=bot
WHATSAPP_DM_POLICY=open
WHATSAPP_GROUP_POLICY=disabled

# Evolution API (shared number)
EVOLUTION_URL=https://your-evolution.example.com
EVOLUTION_INSTANCE=YourInstance
EVOLUTION_APIKEY=your-evolution-api-key

# Phone filter — only process messages from these numbers (comma-separated)
# Leave empty to accept all
ALLOWED_PHONES=

# Groq (free) — audio transcription + image understanding
# Get free key at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your-groq-api-key

# Qdrant RAG (optional — Singular Memory)
QDRANT_URL=http://your-qdrant:6333
QDRANT_API_KEY=your-qdrant-api-key
