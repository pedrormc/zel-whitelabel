# ==============================================================
# Zel — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env && chmod 600 .env
# ==============================================================

# --- Evolution API (gateway WhatsApp) ---
# URL base da sua instância Evolution API
# Se roda em Docker na mesma VPS: http://172.17.0.X:8080
# Se separada com domínio: https://evolution.seu-dominio.com
EVOLUTION_URL=https://evolution.seu-dominio.com

# Nome da instância criada na Evolution API (você cria com o nome que quiser)
EVOLUTION_INSTANCE=Zel

# API key da instância (gerada ao criar a instância, NÃO é a global da Evolution)
EVOLUTION_APIKEY=sua-api-key-aqui

# --- Número autorizado ---
# Número do WhatsApp do DONO — o Zel só responde mensagens vindas desse número.
# Formato: DDI + DDD + número, sem +, sem espaços, sem traços.
# Exemplo Brasil: 5561999999999
# Exemplo Portugal: 351999999999
# Exemplo USA: 14155551234
OWNER_WHATSAPP_NUMBER=5500000000000

# --- OpenAI (Whisper — transcrição de áudio) ---
# Chave da API da OpenAI para transcrição de áudio via Whisper
# Gere em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Servidor HTTP ---
# Porta do webhook server (nginx faz proxy pra cá)
PORT=3333

# --- Plaud Webhook (opcional — recebe transcrições do Plaud via n8n) ---
# Bearer token compartilhado com o n8n. Gerar com: openssl rand -hex 32
# Deixe em branco se você não usa Plaud
PLAUD_WEBHOOK_TOKEN=

# Diretório onde transcrições recebidas são salvas
TRANSCRIPTS_DIR=/home/USER/zel/plaud-transcripts

# --- Paths ---
# Caminho absoluto do vault Obsidian (clone do seu repo git)
# Ajuste conforme seu usuário e estrutura
VAULT_PATH=/home/USER/vault

# Caminho absoluto do diretório do Zel
ZEL_HOME=/home/USER/zel

# --- Claude Code OAuth Token (opcional) ---
# Se você usa autenticação OAuth do Claude Max/Pro em vez de API key
# Gerar com: claude setup-token (veja docs/SETUP-VPS.md)
# CLAUDE_CODE_OAUTH_TOKEN=

# --- Sessão ---
# Máximo de mensagens antes de rotacionar a sessão (default: 50)
SESSION_MAX_MESSAGES=50
